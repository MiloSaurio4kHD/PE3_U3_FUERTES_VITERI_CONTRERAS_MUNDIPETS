        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;erDiagram\n\n    USUARIO {\n        INT id_usuario PK\n        VARCHAR nombres\n        VARCHAR apellidos\n        VARCHAR correo UK\n        VARCHAR contrasena_hash\n        VARCHAR telefono\n        VARCHAR ubicacion\n        VARCHAR tipo_usuario\n        VARCHAR estado\n        DATETIME fecha_registro\n    }\n\n    MASCOTA {\n        INT id_mascota PK\n        VARCHAR nombre\n        VARCHAR especie\n        VARCHAR raza\n        CHAR sexo\n        DATE fecha_nacimiento\n        VARCHAR color\n        DECIMAL peso\n        VARCHAR temperamento\n        VARCHAR estado_reproductivo\n        VARCHAR estado_perfil\n        DATETIME fecha_registro\n    }\n\n    USUARIO_MASCOTA {\n        INT id_usuario_mascota PK\n        INT id_usuario FK\n        INT id_mascota FK\n        VARCHAR tipo_relacion\n        BOOLEAN es_responsable_principal\n        DATE fecha_asignacion\n    }\n\n    HISTORIAL_MEDICO {\n        INT id_historial PK\n        INT id_mascota FK\n        TEXT enfermedades_previas\n        TEXT enfermedades_cronicas\n        TEXT alergias\n        TEXT cirugias_previas\n        TEXT tratamientos_actuales\n        TEXT antecedentes_geneticos\n        TEXT observaciones\n        DATETIME fecha_actualizacion\n    }\n\n    VACUNA {\n        INT id_vacuna PK\n        VARCHAR nombre UK\n        VARCHAR descripcion\n        VARCHAR especie_aplicable\n        INT numero_dosis\n        INT periodicidad_meses\n    }\n\n    REGISTRO_VACUNACION {\n        INT id_registro_vacunacion PK\n        INT id_mascota FK\n        INT id_vacuna FK\n        DATE fecha_aplicacion\n        DATE fecha_proxima_dosis\n        INT numero_dosis\n        VARCHAR lote\n        TEXT observaciones\n        BOOLEAN validada\n    }\n\n    DOCUMENTO_VETERINARIO {\n        INT id_documento PK\n        INT id_mascota FK\n        INT id_usuario_carga FK\n        VARCHAR tipo_documento\n        VARCHAR nombre_archivo\n        VARCHAR ruta_archivo\n        DATE fecha_emision\n        DATETIME fecha_carga\n        VARCHAR estado_validacion\n    }\n\n    PUBLICACION {\n        INT id_publicacion PK\n        INT id_usuario FK\n        INT id_mascota FK\n        VARCHAR tipo_publicacion\n        VARCHAR titulo\n        TEXT descripcion\n        VARCHAR ubicacion\n        DATETIME fecha_publicacion\n        VARCHAR estado\n    }\n\n    SOLICITUD_ADOPCION {\n        INT id_solicitud_adopcion PK\n        INT id_publicacion FK\n        INT id_solicitante FK\n        TEXT motivo\n        TEXT condiciones_hogar\n        TEXT experiencia_mascotas\n        DATETIME fecha_solicitud\n        VARCHAR estado\n        TEXT observacion_respuesta\n    }\n\n    SOLICITUD_CRUZA {\n        INT id_solicitud_cruza PK\n        INT id_publicacion FK\n        INT id_mascota_solicitante FK\n        INT id_usuario_solicitante FK\n        DATETIME fecha_solicitud\n        VARCHAR resultado_compatibilidad\n        VARCHAR nivel_riesgo\n        VARCHAR estado\n        TEXT observaciones\n    }\n\n    MENSAJE {\n        INT id_mensaje PK\n        INT id_remitente FK\n        INT id_destinatario FK\n        INT id_solicitud_adopcion FK\n        INT id_solicitud_cruza FK\n        TEXT contenido\n        DATETIME fecha_envio\n        BOOLEAN leido\n        VARCHAR estado_moderacion\n    }\n\n    VALIDACION_MEDICA {\n        INT id_validacion PK\n        INT id_documento FK\n        INT id_veterinario FK\n        VARCHAR resultado\n        TEXT observaciones\n        DATETIME fecha_validacion\n    }\n\n    USUARIO ||--o{ USUARIO_MASCOTA : administra\n    MASCOTA ||--|{ USUARIO_MASCOTA : tiene\n\n    MASCOTA ||--o| HISTORIAL_MEDICO : posee\n\n    MASCOTA ||--o{ REGISTRO_VACUNACION : recibe\n    VACUNA ||--o{ REGISTRO_VACUNACION : corresponde\n\n    USUARIO ||--o{ PUBLICACION : crea\n    MASCOTA ||--o{ PUBLICACION : aparece_en\n\n    MASCOTA ||--o{ DOCUMENTO_VETERINARIO : posee\n    USUARIO ||--o{ DOCUMENTO_VETERINARIO : carga\n\n    PUBLICACION ||--o{ SOLICITUD_ADOPCION : recibe\n    USUARIO ||--o{ SOLICITUD_ADOPCION : solicita\n\n    PUBLICACION ||--o{ SOLICITUD_CRUZA : recibe\n    USUARIO ||--o{ SOLICITUD_CRUZA : solicita\n    MASCOTA ||--o{ SOLICITUD_CRUZA : participa\n\n    USUARIO ||--o{ MENSAJE : envia\n    USUARIO ||--o{ MENSAJE : recibe\n\n    SOLICITUD_ADOPCION o|--o{ MENSAJE : genera\n    SOLICITUD_CRUZA o|--o{ MENSAJE : genera\n\n    DOCUMENTO_VETERINARIO ||--o{ VALIDACION_MEDICA : recibe\n    USUARIO ||--o{ VALIDACION_MEDICA : realiza&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="c-qUhfE4dFP9vQLtHsM0-233">
