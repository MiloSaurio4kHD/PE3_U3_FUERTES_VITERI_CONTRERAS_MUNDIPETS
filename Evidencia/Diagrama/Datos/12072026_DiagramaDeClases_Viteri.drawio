  <diagram name="Página-1" id="WjqP8IDy5geOfzLnM0bL">
    <mxGraphModel dx="2271" dy="1467" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;classDiagram\n\nclass Usuario {\n    -int idUsuario\n    -string nombres\n    -string apellidos\n    -string correo\n    -string contrasenaHash\n    -string telefono\n    -string ubicacion\n    -string tipoUsuario\n    -string estado\n    -datetime fechaRegistro\n\n    +registrarUsuario()\n    +actualizarPerfil()\n    +iniciarSesion()\n    +cambiarEstado()\n}\n\nclass Mascota {\n    -int idMascota\n    -string nombre\n    -string especie\n    -string raza\n    -char sexo\n    -date fechaNacimiento\n    -string color\n    -decimal peso\n    -string temperamento\n    -string estadoReproductivo\n    -string estadoPerfil\n    -datetime fechaRegistro\n\n    +registrarMascota()\n    +actualizarDatos()\n    +consultarPerfil()\n    +cambiarEstadoPerfil()\n}\n\nclass UsuarioMascota {\n    -int idUsuarioMascota\n    -int idUsuario\n    -int idMascota\n    -string tipoRelacion\n    -boolean responsablePrincipal\n    -date fechaAsignacion\n\n    +asignarResponsable()\n    +cambiarTipoRelacion()\n    +establecerResponsablePrincipal()\n}\n\nclass HistorialMedico {\n    -int idHistorial\n    -int idMascota\n    -string enfermedadesPrevias\n    -string enfermedadesCronicas\n    -string alergias\n    -string cirugiasPrevias\n    -string tratamientosActuales\n    -string antecedentesGeneticos\n    -string observaciones\n    -datetime fechaActualizacion\n\n    +registrarAntecedente()\n    +actualizarHistorial()\n    +consultarHistorial()\n}\n\nclass Vacuna {\n    -int idVacuna\n    -string nombre\n    -string descripcion\n    -string especieAplicable\n    -int numeroDosis\n    -int periodicidadMeses\n\n    +registrarVacuna()\n    +actualizarVacuna()\n    +consultarEsquema()\n}\n\nclass RegistroVacunacion {\n    -int idRegistroVacunacion\n    -int idMascota\n    -int idVacuna\n    -date fechaAplicacion\n    -date fechaProximaDosis\n    -int numeroDosis\n    -string lote\n    -string observaciones\n    -boolean validada\n\n    +registrarAplicacion()\n    +programarProximaDosis()\n    +validarRegistro()\n}\n\nclass DocumentoVeterinario {\n    -int idDocumento\n    -int idMascota\n    -int idUsuarioCarga\n    -string tipoDocumento\n    -string nombreArchivo\n    -string rutaArchivo\n    -date fechaEmision\n    -datetime fechaCarga\n    -string estadoValidacion\n\n    +cargarDocumento()\n    +consultarDocumento()\n    +actualizarEstadoValidacion()\n}\n\nclass Publicacion {\n    -int idPublicacion\n    -int idUsuario\n    -int idMascota\n    -string tipoPublicacion\n    -string titulo\n    -string descripcion\n    -string ubicacion\n    -datetime fechaPublicacion\n    -string estado\n\n    +crearPublicacion()\n    +editarPublicacion()\n    +cerrarPublicacion()\n    +consultarPublicacion()\n}\n\nclass SolicitudAdopcion {\n    -int idSolicitudAdopcion\n    -int idPublicacion\n    -int idSolicitante\n    -string motivo\n    -string condicionesHogar\n    -string experienciaMascotas\n    -datetime fechaSolicitud\n    -string estado\n    -string observacionRespuesta\n\n    +crearSolicitud()\n    +evaluarSolicitud()\n    +aprobarSolicitud()\n    +rechazarSolicitud()\n    +cancelarSolicitud()\n}\n\nclass SolicitudCruza {\n    -int idSolicitudCruza\n    -int idPublicacion\n    -int idMascotaSolicitante\n    -int idUsuarioSolicitante\n    -datetime fechaSolicitud\n    -string resultadoCompatibilidad\n    -string nivelRiesgo\n    -string estado\n    -string observaciones\n\n    +crearSolicitud()\n    +evaluarCompatibilidad()\n    +aprobarSolicitud()\n    +rechazarSolicitud()\n}\n\nclass Mensaje {\n    -int idMensaje\n    -int idRemitente\n    -int idDestinatario\n    -int idSolicitudAdopcion\n    -int idSolicitudCruza\n    -string contenido\n    -datetime fechaEnvio\n    -boolean leido\n    -string estadoModeracion\n\n    +enviarMensaje()\n    +marcarComoLeido()\n    +moderarContenido()\n}\n\nclass ValidacionMedica {\n    -int idValidacion\n    -int idDocumento\n    -int idVeterinario\n    -string resultado\n    -string observaciones\n    -datetime fechaValidacion\n\n    +validarDocumento()\n    +rechazarDocumento()\n    +registrarObservacion()\n}\n\nUsuario \&quot;1\&quot; --&gt; \&quot;0..*\&quot; UsuarioMascota : participa\nMascota \&quot;1\&quot; --&gt; \&quot;1..*\&quot; UsuarioMascota : tiene responsables\n\nMascota \&quot;1\&quot; *-- \&quot;0..1\&quot; HistorialMedico : posee\n\nMascota \&quot;1\&quot; --&gt; \&quot;0..*\&quot; RegistroVacunacion : recibe\nVacuna \&quot;1\&quot; --&gt; \&quot;0..*\&quot; RegistroVacunacion : corresponde\n\nUsuario \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Publicacion : crea\nMascota \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Publicacion : aparece en\n\nMascota \&quot;1\&quot; *-- \&quot;0..*\&quot; DocumentoVeterinario : posee\nUsuario \&quot;1\&quot; --&gt; \&quot;0..*\&quot; DocumentoVeterinario : carga\n\nPublicacion \&quot;1\&quot; --&gt; \&quot;0..*\&quot; SolicitudAdopcion : recibe\nUsuario \&quot;1\&quot; --&gt; \&quot;0..*\&quot; SolicitudAdopcion : solicita\n\nPublicacion \&quot;1\&quot; --&gt; \&quot;0..*\&quot; SolicitudCruza : recibe\nUsuario \&quot;1\&quot; --&gt; \&quot;0..*\&quot; SolicitudCruza : solicita\nMascota \&quot;1\&quot; --&gt; \&quot;0..*\&quot; SolicitudCruza : participa\n\nUsuario \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Mensaje : envia\nUsuario \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Mensaje : recibe\n\nSolicitudAdopcion \&quot;0..1\&quot; --&gt; \&quot;0..*\&quot; Mensaje : genera\nSolicitudCruza \&quot;0..1\&quot; --&gt; \&quot;0..*\&quot; Mensaje : genera\n\nDocumentoVeterinario \&quot;1\&quot; --&gt; \&quot;0..*\&quot; ValidacionMedica : recibe\nUsuario \&quot;1\&quot; --&gt; \&quot;0..*\&quot; ValidacionMedica : realiza&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="c-qUhfE4dFP9vQLtHsM0-1">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=20;" vertex="1">
